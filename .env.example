NEXT_PUBLIC_SUPABASE_URL=
# Supabase > Project Settings > API > Publishable key (recommended)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy projects can still use anon key if needed
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase > Project Settings > API > Secret key (recommended for server-side admin ops)
SUPABASE_SECRET_KEY=
# Legacy projects can still use service_role key if needed
SUPABASE_SERVICE_ROLE_KEY=
